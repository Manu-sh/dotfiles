// Project tasks configuration. See https://zed.dev/docs/tasks for documentation.
[
  {
    "label": "Arduino UNO - disassembly (radare2)",
    "command": "r2 -2q build/uno/firmware.elf <<< 'aaa;pdf@main'",
    "use_new_terminal": false,
  },
  {
    "label": "Arduino UNO - detect",
    "command": "arduino-cli board list -b arduino:avr:uno|grep -o '^.*tty\\S*' || echo $'\\033[38;5;9m' 'detect: arduino-uno undetected' $'\\033[0m'",
    "use_new_terminal": false,
  },

  {
    "label": "Arduino UNO - build (platformio)",
    "command": "pio run -c platformio.ini -v -j $(nproc --all)",
    "use_new_terminal": false,
  },

  {
    "label": "Arduino UNO - load (platformio)",
    "command": "pio run --target upload --disable-auto-clean --target nobuild",
    "use_new_terminal": false,
  },

  /*
  {
    "label": "Arduino UNO - build & load (platformio)",
    "command": "pio run -c platformio.ini -v -j $(nproc --all) --target upload",
    "use_new_terminal": false,
  },
  */

  {
    "label": "Arduino UNO - release",
    "command": "pio run -c platformio.ini -v -j $(nproc --all) && avr-strip -s build/uno/firmware.elf && pio run --target upload --disable-auto-clean --target nobuild",
    "use_new_terminal": false,
  },

  {
    "label": "Arduino UNO - serial (platformio)",
    "command": "pio device monitor -b 9600",
    "use_new_terminal": true,
  },

  /*
  {
    "label": "Arduino UNO - build",
    "command": "arduino-cli compile -b arduino:avr:uno $ZED_FILE -ej $(nproc --all)",
    "use_new_terminal": false,
  },

  {
    "label": "Arduino UNO - load",
    "command": "arduino-cli upload -p \"$(arduino-cli board list -b arduino:avr:uno|grep -o '^.*tty\\S*')\" -b arduino:avr:uno --build-path ./build/arduino.avr.uno",
    "use_new_terminal": false,
  },

  {
    "label": "Arduino UNO - build/load",
    "command": "arduino-cli compile -b arduino:avr:uno $ZED_FILE && arduino-cli upload -p \"$(arduino-cli board list -b arduino:avr:uno|grep -o '^.*tty\\S*')\" -b arduino:avr:uno $ZED_FILE",

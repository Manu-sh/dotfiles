// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent": {
    "default_model": {
      "provider": "ollama",
      "model": "huihui_ai/qwen3.5-abliterated:4B-q8_0",
      "enable_thinking": false,
    },
    "favorite_models": [],
    "model_parameters": [],
  },

  "language_models": {
    "ollama": {
      "api_url": "http://localhost:11434",
      "auto_discover": true,
      "available_models": [
        {
          "name": "huihui_ai/qwen3.5-abliterated:4B-q8_0",
          "display_name": "huihui_ai/qwen3.5-abliterated:4B-q8_0",
          "max_tokens": 12288,
          "supports_tools": true,
          "supports_thinking": true,
          "supports_images": true,
        },
      ],
    },
  },

  "title_bar": {
    "show_menus": true,
    "show_branch_icon": true,
  },
  "use_system_window_tabs": false,
  "debugger": {
    "button": true,
  },
  "terminal": {
    "button": true,
  },
  "status_bar": {
    "cursor_position_button": true,
    "active_language_button": true,
  },
  "project_panel": {},
  "file_types": {
    "Arduino": ["ino"],
  },

  "base_keymap": "JetBrains",
  "indent_guides": {
    "enabled": false,
  },
  "show_wrap_guides": false,
  "buffer_font_family": "Fira Code",
  "session": {
    "trust_all_worktrees": true,
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": "One Dark",
}
